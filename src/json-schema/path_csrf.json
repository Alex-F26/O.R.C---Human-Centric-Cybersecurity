          "choices": [
            { "value": "burp_csrf",     "text": "reeee [costs 2 min]" },
            { "value": "manual_review", "text": "reeee [costs 1 min]" },
            { "value": "check_cookies", "text": "reeee [costs 1 min]" },
            { "value": "owasp_zap",     "text": "reeee [costs 3 min]" }
          ]
        }
      ]
    },
    {
      "name": "csrf_2",
      "title": "Path C — CSRF Attack | Step 2: ???",
